# Compiled
*.elc

# Packaging
.cask/
.eask/
.eldev/
.keg/

# Built distribution
dist/

# Backup files
*~

# Runtime request/body logs
/image-read.log

# Undo-tree save-files
*.~undo-tree

# Local mevedel project state.  Runtime sessions, hook config, plans, and
# hints can contain absolute paths and prompt history; only project-local
# skills are candidates for version control in this repository.
!/.mevedel/
.mevedel/*
!.mevedel/skills
!.mevedel/hooks.json
!.mevedel/hooks

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class
